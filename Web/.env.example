# Portability Configuration
# Copy this file to .env and customize values for your machine

# Firefox executable path (leave empty to auto-detect from system PATH)
# FIREFOX_BIN=/usr/bin/firefox
# FIREFOX_BIN=/opt/firefox/firefox
# FIREFOX_BIN=/snap/bin/firefox

# Foxhound executable path (leave empty to auto-detect from project structure)
# FOXHOUND_BIN=./foxhound-engine/foxhound/foxhound

# Foxhound results directory (leave empty to auto-detect from project structure)
# FOXHOUND_RESULTS_DIR=./foxhound-engine/results
